PORT=3000
# Local Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/Story
# MongoDB Atlas example (note the DB name in the path: /chomchom or /Story)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/chomchom?retryWrites=true&w=majority&appName=CHOMCHOM
JWT_EXPIRES_IN=7d
JWT_SECRET=your_jwt_secret
NODE_ENV=development

# Payments (VNPay)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
# Sandbox: https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Public base URL of this backend (used to build returnUrl if VNPAY_RETURN_URL is empty)
PUBLIC_BASE_URL=https://your-backend-domain.example.com
# Optional: override the return URL sent to VNPay
# VNPAY_RETURN_URL=https://your-backend-domain.example.com/api/payments/vnpay/return
# Optional: set chapter price coins (default 5)
CHAPTER_PRICE_COINS=5

# Optional / unused in simplified auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
