PORT=3000
# Local Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/Story
# MongoDB Atlas example (note the DB name in the path: /chomchom or /Story)
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/chomchom?retryWrites=true&w=majority&appName=CHOMCHOM
JWT_EXPIRES_IN=7d
JWT_SECRET=your_jwt_secret
NODE_ENV=development

# Payments (Stripe Checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Public base URL of this backend, used for success/cancel URLs in Stripe Checkout
PUBLIC_BASE_URL=https://your-backend-domain.example.com

# Optional / unused in simplified auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
